# Word Teacher - 生产环境配置模板
# =========================================
# 复制此文件为 .env 并填写实际值
# cp .env.production.example .env
#
# ⚠️ 重要：所有配置都在这里管理，不要在其他地方硬编码！
# =========================================

# ============ Docker 镜像版本 ============
IMAGE_TAG=latest

# ============ MySQL 数据库 ============
# 请设置强密码！生成方式: openssl rand -base64 24
MYSQL_ROOT_PASSWORD=your-mysql-root-password
MYSQL_PASSWORD=your-mysql-app-password

# ============ JWT 认证 ============
# 至少 32 字符，生成方式: openssl rand -base64 48
JWT_SECRET=your-jwt-secret-at-least-32-chars

# ============ CORS 跨域 ============
# 允许的前端域名，Cloudflare Tunnel 会动态分配
# 生产环境建议设置为 * 或具体的 trycloudflare.com 域名
CORS_ORIGINS=*

# ============ Agent 服务 ============
# Backend 和 Agent 之间的共享密钥，生成方式: openssl rand -base64 32
AGENT_API_KEY=your-agent-api-key

# ============ MinIO 对象存储 ============
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=your-minio-password
MINIO_BUCKET=covers
# ⚠️ 重要：使用相对路径，不要写完整域名！
MINIO_PUBLIC_PATH=/minio

# ============ 阿里云 AI 服务 ============
# Dashscope API Key (用于 Qwen 模型)
# 获取地址: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=your-dashscope-api-key

# 阿里云智能语音交互 - 一句话识别 (STT)
# 用于对话场景中的语音转文字，成本比 Qwen-Omni 低
# 获取地址: https://nls-portal.console.aliyun.com/
ALIYUN_STT_APPKEY=your-aliyun-stt-appkey
# 方式1: 直接配置 Token（测试用，有效期约 24 小时）
ALIYUN_STT_TOKEN=your-token-here
# 方式2: 配置 AccessKey，自动获取 Token（推荐生产环境）
# ALIYUN_AK_ID=your-aliyun-access-key-id
# ALIYUN_AK_SECRET=your-aliyun-access-key-secret

