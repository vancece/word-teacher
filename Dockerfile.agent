# Word Teacher Agent - Docker 镜像
# AI Agent 服务，处理语音识别和对话

FROM node:20-alpine AS builder

WORKDIR /app

# 安装 pnpm
RUN npm install -g pnpm

# 先复制依赖文件（利用 Docker 层缓存，依赖不变就不重装）
COPY agent/package.json ./
COPY agent/pnpm-lock.yaml ./

# 安装依赖
RUN pnpm install --frozen-lockfile

# 再复制源码（源码变了只重新 build，不重装依赖）
COPY agent/src ./src/
COPY agent/tsconfig.json ./

# 构建 TypeScript
RUN pnpm build

# 生产阶段只装 production 依赖，去掉 devDependencies
RUN pnpm prune --prod

# ============ 生产镜像 ============
FROM node:20-alpine AS runner

WORKDIR /app

# 只复制必要的文件（不需要 pnpm，用 node 直接跑）
COPY --from=builder /app/dist ./dist
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/package.json ./

# 创建日志目录 + 非 root 用户
RUN mkdir -p /app/logs \
    && addgroup --system --gid 1001 nodejs \
    && adduser --system --uid 1001 agent \
    && chown -R agent:nodejs /app/logs
USER agent

# 健康检查（访问根路径，不需要认证）
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
  CMD wget --no-verbose --tries=1 -q -O /dev/null http://localhost:3002/ || exit 1

EXPOSE 3002

ENV NODE_ENV=production
ENV PORT=3002

CMD ["node", "dist/index.js"]

