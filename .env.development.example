# ================================
# 本地开发环境配置模板
# 复制为 .env.development 并填入实际值
# cp .env.development.example .env.development
# ================================

# ============ 数据库 (MySQL) ============
# Docker 开发环境默认配置
DATABASE_URL="mysql://wordteacher:dev123456@localhost:3306/word_teacher"
MYSQL_ROOT_PASSWORD=root123456
MYSQL_PASSWORD=dev123456

# ============ JWT ============
JWT_SECRET="local-dev-jwt-secret-not-for-production"
JWT_EXPIRES_IN="7d"

# ============ CORS ============
CORS_ORIGINS="http://localhost:5173,http://localhost:5174,http://localhost:3000"

# ============ Agent 服务 ============
AGENT_URL="http://localhost:3002/api/agent"
AGENT_API_KEY="local-dev-agent-key"

# ============ MinIO 对象存储 ============
# Docker 开发环境默认配置
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=covers
MINIO_USE_SSL=false

# ============ AI API (阿里云 DashScope) ============
# ⚠️ 需要自己申请 API Key: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=your-dashscope-api-key-here
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ============ 阿里云智能语音交互 (STT 一句话识别) ============
# 用于对话场景语音转文字，成本比 Qwen-Omni 低
# 获取地址: https://nls-portal.console.aliyun.com/
# 方式1: 直接配置 Token（测试用，有效期约 24 小时）
# 方式2: 配置 AccessKey，自动获取 Token（推荐生产环境）
ALIYUN_STT_APPKEY=your-aliyun-stt-appkey
ALIYUN_STT_TOKEN=your-token-here
# ALIYUN_AK_ID=your-access-key-id
# ALIYUN_AK_SECRET=your-access-key-secret

