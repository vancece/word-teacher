# ================================
# OpenAI / Dashscope 配置
# 使用阿里云 Dashscope 兼容 OpenAI 接口
# ================================
OPENAI_API_KEY=sk-your-dashscope-api-key-here
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=qwen-plus

# Dashscope API Key (用于翻译、ASR 等服务，与上面相同)
DASHSCOPE_API_KEY=sk-your-dashscope-api-key-here

# ================================
# 阿里云智能语音交互 - 一句话识别 (STT)
# 用于对话场景中的语音转文字，成本比 Qwen-Omni 低
# 获取地址: https://nls-portal.console.aliyun.com/
# ================================
ALIYUN_STT_APPKEY=your-aliyun-stt-appkey
# 方式1: 直接配置 Token（测试用，有效期约 24 小时）
ALIYUN_STT_TOKEN=your-token-here
# 方式2: 配置 AccessKey，自动获取 Token（推荐生产环境）
# ALIYUN_AK_ID=your-aliyun-access-key-id
# ALIYUN_AK_SECRET=your-aliyun-access-key-secret

# ================================
# Server Configuration
# ================================
PORT=8000
NODE_ENV=development  # development | production

# ================================
# Agent API Key 认证
# 生产环境必须设置，与 Backend 的 AGENT_API_KEY 保持一致
# ================================
AGENT_API_KEY=your-agent-api-key-change-in-production

# ================================
# Backend API (for fetching scene data)
# ================================
BACKEND_API_URL=http://localhost:3001/api

# ================================
# CORS (允许的前端域名，逗号分隔)
# 生产环境设置为你的域名
# ================================
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

