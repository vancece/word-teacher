// ==================== 跟读功能 ====================

// 跟读场景表
model ReadAloudScene {
  id          String   @id @db.VarChar(20)
  name        String   @db.VarChar(50)           // 场景名称
  description String?  @db.Text                   // 场景描述
  coverImage  String?  @db.MediumText            // 封面图片 (base64)
  grade       String   @default("基础") @db.VarChar(20)  // 难度等级
  visible     Boolean  @default(true)            // 是否对学生可见
  sentences   Json                                // 句子数组 [{id, english, chinese, audio}]
  creatorId   Int?     @map("creator_id")         // 创建者教师ID
  createdAt   DateTime @default(now()) @map("created_at")

  // 关联
  practiceRecords ReadAloudRecord[]
  creator         Teacher? @relation("ReadAloudSceneCreator", fields: [creatorId], references: [id], onDelete: SetNull)

  @@map("read_aloud_scenes")
}

// 跟读练习记录表
model ReadAloudRecord {
  id              Int            @id @default(autoincrement())
  studentId       Int            @map("student_id")
  sceneId         String         @map("scene_id") @db.VarChar(20)

  // 基础信息
  completedCount  Int            @default(0) @map("completed_count")  // 已完成句子数
  totalCount      Int            @map("total_count")         // 总句子数
  durationSeconds Int?           @map("duration_seconds")    // 练习时长
  status          PracticeStatus @default(IN_PROGRESS)

  // 每句评分详情 [{english, chinese, spokenText, accuracy, feedback}]
  sentenceResults Json?          @map("sentence_results")

  // AI 整体评分 (1-5星制，4个维度)
  totalScore       Int?        @map("total_score")        // 总分 1-5
  intonationScore  Int?        @map("intonation_score")   // 语音语调 1-5
  fluencyScore     Int?        @map("fluency_score")      // 流利连贯 1-5
  accuracyScore    Int?        @map("accuracy_score")     // 准确完整 1-5
  expressionScore  Int?        @map("expression_score")   // 情感表现力 1-5

  // AI 反馈
  feedback     String?  @db.Text                    // 老师评语
  strengths    Json?                                // 亮点 ["...", "..."]
  improvements Json?                                // 建议 ["...", "..."]

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // 关联 - 删除学生时级联删除跟读记录
  student Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  scene   ReadAloudScene @relation(fields: [sceneId], references: [id])

  // 索引优化查询性能
  @@index([studentId])
  @@index([sceneId])
  @@index([createdAt])
  @@index([studentId, createdAt])
  @@map("read_aloud_records")
}

