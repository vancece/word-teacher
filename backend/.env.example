# ================================
# 服务器配置
# ================================
PORT=3001
NODE_ENV=development  # development | production | test

# ================================
# 数据库配置 (MySQL)
# ================================
DATABASE_URL="mysql://root:your-password@localhost:3306/word_teacher"

# ================================
# JWT 配置
# 生产环境请使用 64+ 字符的随机字符串
# 可用命令生成: openssl rand -base64 48
# ================================
JWT_SECRET="your-super-secret-jwt-key-change-in-production-at-least-32-chars"
JWT_EXPIRES_IN="7d"

# ================================
# CORS 配置
# 生产环境设置为你的前端域名，多个用逗号分隔
# ================================
CORS_ORIGINS="http://localhost:5173,http://localhost:5174"

# ================================
# Agent 服务配置 (AI 对话/评分服务)
# ================================
AGENT_URL="http://localhost:8000/api/agent"
# Agent 服务间通信密钥（需与 Agent 的 AGENT_API_KEY 一致）
AGENT_API_KEY="your-agent-api-key-change-in-production"

# ================================
# AI / Embedding 配置（AI 助手 + 向量搜索）
# 用于知识库向量化和 AI 助手回答
# 使用阿里云 DashScope API Key（与 Agent 共用同一个即可）
# ================================
AI_API_KEY="sk-your-dashscope-api-key"
AI_API_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"

# ================================
# LanceDB 向量数据库路径（可选，默认 ./data/lancedb）
# 生产环境通过 docker-compose volume 挂载
# ================================
# LANCEDB_PATH="./data/lancedb"

# ================================
# AI 助手机器人账号（钉钉等外部渠道使用）
# 填写后台教师账号的用户名，AI 助手将以该教师身份查询/操作数据
# 不配置则默认以第一个管理员身份运行
# ================================
# ASSISTANT_BOT_USERNAME="assistant-bot"

# ================================
# 钉钉 AI 客服机器人（可选）
# 独立于通知机器人，用于老师在钉钉群/私聊中 @机器人 提问
# 在钉钉开放平台创建企业内部应用 → 机器人能力 → 获取凭证
# ================================
# DINGTALK_BOT_APP_KEY=""
# DINGTALK_BOT_APP_SECRET=""
# DINGTALK_BOT_TOKEN=""

# ================================
# 钉钉通知机器人（可选，用于学生练习完成通知老师）
# ================================
# DINGTALK_ACCESS_TOKEN=""
# DINGTALK_SECRET=""

